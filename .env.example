# Local backup destination. Each run creates a dated folder such as
# /var/backups/automated-server-backup/20260405/
# and stores one .tar file per inclusion inside it.
BACKUP_ROOT=/var/backups/automated-server-backup

# Log file
LOG_FILE=/var/log/automated-server-backup.log

# Keep only the latest 4 days of backups locally and remotely
RETENTION_DAYS=4

# Add a safety margin to the estimated disk-space requirement
ESTIMATE_MARGIN_PERCENT=20

# Upload provider. Supported values:
#   rclone                 — use rclone (default, requires RCLONE_REMOTE below)
#   gdrive_service_account — use a Google service account (requires GDRIVE_* vars below)
#   none                   — skip remote upload entirely
UPLOAD_PROVIDER=rclone

# --- rclone settings (used when UPLOAD_PROVIDER=rclone) ---
# Set this after configuring rclone for Google Drive or another supported remote.
# Example:
# RCLONE_REMOTE=gdrive:server-backups
RCLONE_REMOTE=

# --- Google service account settings (used when UPLOAD_PROVIDER=gdrive_service_account) ---
# Absolute path to the service account JSON key file.
GDRIVE_SERVICE_ACCOUNT_JSON=
# The ID of the Google Shared Drive (Team Drive) to upload into.
# Found in the URL when browsing the shared drive: drive.google.com/drive/u/0/folders/<id>
GDRIVE_SHARED_DRIVE_ID=
# The ID of the parent folder inside the shared drive where dated backup folders are created.
GDRIVE_PARENT_FOLDER_ID=

# Optional alerting when free disk space is too low for a backup run.
# Supported values:
# ALERT_PROVIDER=telegram
# ALERT_PROVIDER=google_chat
# ALERT_PROVIDER=teams
ALERT_PROVIDER=

# Used by Google Chat or Teams webhook alerts.
ALERT_WEBHOOK_URL=

# Used by Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional message prefix.
ALERT_TITLE="Automated Server Backup Alert"

# Inclusion list used by the backup script. Format is name:path:mode per line.
INCLUSION_LIST_FILE=/var/automated-server-backup/directory-inclusions.txt
